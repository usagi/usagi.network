---
const { item } = Astro.props;
const repoUrl = `https://github.com/${item.repo}`;
const releaseUrl = `${repoUrl}/releases`;
const actions = [
 { label: 'Repository', url: repoUrl, kind: 'primary' },
 { label: 'Releases', url: releaseUrl, kind: 'secondary' },
 ...(item.links || []).map(link => ({ label: link.label, url: link.url, kind: 'secondary' })),
];
---
<article class="feature software-feature">
 <div class="feature__media software-media">
  <img class="software-media__shot" src={item.media?.screenshot || ''} alt={`${item.title} screenshot`} loading="lazy" decoding="async" />
  <img class="software-media__icon" src={item.media?.icon || ''} alt="" loading="lazy" decoding="async" />
 </div>
 <div class="feature__body">
  <div class="feature__meta">
   <span class="tag">{item.tag}</span>
   <span class="sub">{item.fallbackVersion}</span>
  </div>
  <h3 class="feature__title">{item.title}</h3>
  <p class="feature__desc">{item.description}</p>
  <div class="software-specs" aria-label={`${item.title} features`}>
   {(item.specs || []).map(spec => <span>{spec}</span>)}
  </div>
  <div class="software-actions" aria-label={`${item.title} links`}>
   <span class="software-actions__label">External Links</span>
   <div class="software-actions__links">
    {actions.map(action => (
     <a class={`btn ${action.kind === 'primary' ? '' : 'btn--ghost'}`} href={action.url} target="_blank" rel="noopener">{action.label}</a>
    ))}
   </div>
  </div>
 </div>
</article>
