---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/site.js';
import soundcloudData from '../../../assets/data/soundcloud-tracks.json';

const tracks = soundcloudData.tracks || [];
---
<BaseLayout active="music" title="Music" description="USAGI.NETWORK music releases and SoundCloud archive.">
 <h1>Music</h1>
 <div class="music-note">
  音楽コンテンツは主に <a href="https://soundcloud.com/usagi-network" target="_blank" rel="noopener">SoundCloud</a> にて公開しています。
 </div>
 <section class="sc-player" aria-label="SoundCloud player">
  <iframe title="SoundCloud profile player" width="100%" height="166" scrolling="no" frameborder="no" allow="autoplay" src="https://w.soundcloud.com/player/?url=https%3A%2F%2Fsoundcloud.com%2Fusagi-network&auto_play=false&visual=false&show_user=false&show_teaser=false&show_comments=false&show_reposts=false&buying=false&sharing=false&download=false"></iframe>
 </section>
 <section class="strip">
  <h2 class="strip__title">Tracks</h2>
  <div class="features">
   {tracks.map(track => (
    <article class="feature">
     <div class="feature__media">
      {track.artwork_url && <img class="card__thumb" src={track.artwork_url} alt="" loading="lazy" decoding="async" />}
     </div>
     <div class="feature__body">
      <div class="feature__meta"><span class="tag">SoundCloud</span><span class="sub">{formatDate(track.created_at)}</span></div>
      <h3 class="feature__title">{track.title}</h3>
      {track.description && <p class="feature__desc">{track.description.split('\n').slice(0, 3).join(' ')}</p>}
      <div class="feature__actions">
       <a class="btn" href={track.permalink_url} target="_blank" rel="noopener">SoundCloud</a>
      </div>
     </div>
    </article>
   ))}
  </div>
 </section>
</BaseLayout>

