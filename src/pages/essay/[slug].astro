---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEssays } from '../../lib/essays.js';
import { formatDate } from '../../lib/site.js';

export async function getStaticPaths()
{
 const essays = getEssays();
 return essays.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
---
<BaseLayout active="essay" title={entry.data.title} description={entry.data.description || entry.data.subtitle || ''}>
 <article class="essay-article">
  <header class="essay-head">
   <p><a href="/essay/">← Essay</a></p>
   <h1>{entry.data.title}</h1>
   {entry.data.subtitle && <p class="essay-subtitle">{entry.data.subtitle}</p>}
   <p class="essay-byline">{entry.data.author} / {formatDate(entry.data.date)}</p>
   {entry.data.tags?.length > 0 && <p class="essay-tags">{entry.data.tags.map(tag => <span>{tag}</span>)}</p>}
   <div class="feature__actions essay-actions">
    <button class="btn" type="button" onclick="window.print()">Print / PDF</button>
   </div>
  </header>
  <div class="essay-body" set:html={entry.html} />
 </article>
</BaseLayout>
